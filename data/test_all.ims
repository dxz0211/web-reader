{"version":"1.1","metadata":{"title":"综合测试","author":"测试作者","creator":"zcy","description":"测试播放器所有重要功能：入口切换、过渡效果、多句子显示、音频切换、非入口继承"},"assets":{"images":{"rain_street":"data/images/rain_street.jpg","lantern":"data/images/lantern.jpg"},"audios":{"Magic_Waltz":"data/audio/Amedeo Tommasi - Magic Waltz.mp3","Fly_Me_To_The_Moon":"data/audio/Fifties Music - Fly Me To The Moon.mp3","Dream":"data/audio/Al Green - Dream.mp3"}},"timeline":[{"segment_id":1,"entry_point":true,"background":"rain_street","background_music":"Magic_Waltz","transition_effect":"fade_in","sentences":[{"id":1,"text":"雨滴轻轻敲打着窗棂，发出细碎的声响。"},{"id":2,"text":"街道在暮色中渐渐模糊，路灯尚未点亮。"}]},{"segment_id":2,"entry_point":false,"sentences":[{"id":1,"text":"远处传来汽笛的回响，划破了傍晚的宁静。"},{"id":2,"text":"路上行人匆匆而过，撑起五颜六色的伞。"}]},{"segment_id":3,"entry_point":true,"background":"lantern","background_music":"Fly_Me_To_The_Moon","transition_effect":"cross_fade","sentences":[{"id":1,"text":"街灯一盏接一盏亮起，温暖的光晕在雨中散开。"},{"id":2,"text":"橙黄色的光芒映在水洼里，如同破碎的星星。"},{"id":3,"text":"照亮了回家的路，也照亮了等待的心。"}]},{"segment_id":4,"entry_point":true,"background":"rain_street","background_music":"","transition_effect":"cross_fade","sentences":[{"id":1,"text":"雨停了，夜空如洗，云层散去露出几点星光。"},{"id":2,"text":"一切归于宁静，只有远处偶尔传来水滴声。"}]},{"segment_id":5,"entry_point":false,"sentences":[{"id":1,"text":"空气中弥漫着雨后泥土的清香。"},{"id":2,"text":"明天又将是崭新的一天。"}]}]}